<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>

  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <%- include('../includes/U-layout.ejs') %>

    <main class="py-5">
      <div class="container">
        <div class="row">

          <!-- PRODUCT IMAGE -->
          <div class="col-lg-6 mb-4">
            <div class="border rounded p-3 bg-light text-center">
              <img src="<%= product.imageUrl %>" alt="<%= product.Title %>" class="img-fluid"
                style="max-height: 450px; object-fit: contain;" />
            </div>
          </div>

          <!-- PRODUCT INFO -->
          <div class="col-lg-6">
            <h2 class="font-weight-bold mb-2">
              <%= product.Title %>
            </h2>

            <!-- Ratings (static UI) -->
            <div class="mb-2">
              <span class="text-warning">★★★★☆</span>
              <small class="text-muted ml-2">(124 ratings)</small>
            </div>

            <h3 class="text-primary mb-3">$<%= product.price %>
            </h3>

            <span class="badge badge-success mb-3">In Stock</span>

            <p class="mt-4 text-muted">
              <%= product.description %>
            </p>

            <!-- Quantity Selector (UI only) -->
            <div class="form-group w-25">
              <label>Quantity</label>
              <select class="form-control">
                <option>1</option>
                <option>2</option>
                <option>3</option>
              </select>
            </div>

            <!-- ACTION BUTTONS -->
            <form action="/cart" method="POST" class="mb-3">
              <!-- for csfr security token -->
              <input type="hidden" name="_csrf" value="<%= csrfToken%>">
              <button type="submit" class="btn btn-primary btn-lg btn-block">
                Add to Cart
              </button>
              <input type="hidden" name="productId" value="<%= product.id%>">
            </form>

            <a href="/products" class="btn btn-outline-secondary btn-block">
              ← Back to Products
            </a>
          </div>
        </div>

        <!-- PRODUCT HIGHLIGHTS -->
        <hr class="my-5" />

        <div class="row">
          <div class="col-md-4">
            <h5>Why You'll Love It</h5>
            <ul class="text-muted">
              <li>Premium quality materials</li>
              <li>Designed for daily use</li>
              <li>Trusted by thousands of customers</li>
            </ul>
          </div>

          <div class="col-md-4">
            <h5>Shipping & Returns</h5>
            <ul class="text-muted">
              <li>Free delivery within 3–5 days</li>
              <li>7-day easy returns</li>
              <li>Secure packaging guaranteed</li>
            </ul>
          </div>

          <div class="col-md-4">
            <h5>Seller Information</h5>
            <p class="text-muted mb-1">Sold by <strong>ShopMate</strong></p>
            <small class="text-muted">100% positive ratings</small>
          </div>
        </div>

        <!-- REVIEWS SECTION (STATIC UI) -->
        <hr class="my-5" />

        <h4 class="mb-4">Customer Reviews</h4>

        <div class="media mb-4">
          <div class="media-body">
            <h6 class="mt-0">John D. <span class="text-warning">★★★★★</span></h6>
            <p class="text-muted mb-0">
              Amazing product! Build quality is excellent and delivery was fast.
            </p>
          </div>
        </div>

        <div class="media mb-4">
          <div class="media-body">
            <h6 class="mt-0">Sarah K. <span class="text-warning">★★★★☆</span></h6>
            <p class="text-muted mb-0">
              Very satisfied with the purchase. Worth the price.
            </p>
          </div>
        </div>

        <div class="media">
          <div class="media-body">
            <h6 class="mt-0">Alex M. <span class="text-warning">★★★★★</span></h6>
            <p class="text-muted mb-0">
              Highly recommended. Would buy again!
            </p>
          </div>
        </div>

      </div>
    </main>

    <%- include('../includes/B-layout.ejs') %>
</body>

</html>